 function O_CAMUS._code_CPL (var FPL: DFPL4): pchar;
    var   p: pchar;
    begin
      with FPL do p:= StrPasNew
        (
                     _7
         +icao_ARR + _8
         +icao_ARR + _9
         {+icao_ARR + _10}
         +icao_ARR + _13
         +icao_ARR + _14
         +icao_ARR + _16
         +icao_ARR
        );
      p:= StrNCopy(p,FPL._15,true,false);
      p:= StrNCopy(p,FPL._18,true,false);
      _code_CPL:= p
    end;


 function O_CAMUS._code_EST (var FPL: DFPL4): pchar;
    var   p: pchar;
    begin
      with FPL do p:= StrPasNew
        (
                     _7
         +icao_ARR + _8
         +icao_ARR + _9
         +icao_ARR + _13
         +icao_ARR + _14
         +icao_ARR + _16
         +icao_ARR
        );
      p:= StrNCopy(p,FPL._15,true,false);
      p:= StrNCopy(p,FPL._18,true,false);
      _code_EST:= p
    end;


