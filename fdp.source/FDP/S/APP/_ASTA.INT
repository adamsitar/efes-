{----------------------------------------------------------}
{ LINKA OPL :                                              }
{----------------------------------------------------------}
{$IFDEF ASTA_FDP}

{
  (   )Vi
  (
    ESTBR/MI518-SAS779/6256-MD80-EKCH-ODNEM/1400F330-N0440F330-LHBP-ODNEM/330/1400
    BERVA/170/1404 SWCN/170/1405 NIT/170/1407 RUTOL/170/1411 OKI/170/1413
  )Vi
}

procedure ReadCOM_ASTA_FDP; interrupt;
    var   b : byte;
    label endp;
    begin
      if Port[IIR[comASTA_FDP]]<>$04 then goto endp;
      b:= Port[COM[comASTA_FDP]];
      if b=0 then goto endp;

      if (b_FDP.t>=sizeof(b_FDP.b)) then b_FDP.t:= 0;
      b_FDP.b[b_FDP.t]:= chr(b);
      inc(b_FDP.t);

      if (b=$03) then
         begin
           if b_FDP.b[0]='' then save_ASTA_FDP(@b_FDP);
           b_FDP.t:= 0
         end;

      if b=$02 then
         begin
           b_FDP.b[0]:= '';
           b_FDP.t:= 1
         end
      else if (b_FDP.t>2) and (chr(b)='(') then
           begin
             b_FDP.b[0]:= '';
             b_FDP.b[1]:= '(';
             b_FDP.t:= 2
           end;

      endp: Port[$20]:= $20
    end; { ReadCOM_ASTA_FDP }

{$ENDIF}


