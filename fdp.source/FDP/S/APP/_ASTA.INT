   ^J02^T076^E010174                                    ssn
   ^J03^T065^E0201A7307                                 ssr0
   ^J06^T023^E0101S^J06^T024^E02010885                  vys3

   ^,                                                   tlac
   ^X                                                   koniec prenosu

   (   )Vi
}

procedure ReadCOM_ASTA_PRN; interrupt;
    var   b : byte;
    label X;
    begin
      if Port[IIR[comASTA_PRN]]<>$04 then goto X;

      b:= Port[COM[comASTA_PRN]];
      if b=0 then goto X;

      if (b_PRN.t>=sizeof(b_PRN.b)) then b_PRN.t:= 0;
      b_PRN.b[b_PRN.t]:= chr(b);
      inc(b_PRN.t);

      if {(b=$02) or (b=$03) or}
         (b_PRN.t>100) and (chr(b)='X') and (b_PRN.b[b_PRN.t-2]='^')
         (*
              or ({(b_PRN.b[b_PRN.t-3]=',')
                   and} (b_PRN.b[b_PRN.t-2]='^')
                   and  (b_PRN.b[b_PRN.t-1]='X')
                 )
             )*)
              then
          begin
            if b_PRN.b[0]='' then save_ASTA_PRN(@b_PRN);
            b_PRN.t:= 0
          end;

      if b=$05 then
         begin
           b_PRN.b[0]:= ''; {0x5}
           b_PRN.t:= 1
         end
      else if (b_PRN.t>2) and (b_PRN.b[b_PRN.t-1]='A') and (b_PRN.b[b_PRN.t-2]='^') then
           begin
             b_PRN.b[0]:= ''; {0x5}
             b_PRN.b[1]:= '^';
             b_PRN.b[2]:= 'A';
             b_PRN.t:= 3
           end;

      X: Port[$20]:= $20
    end; { ReadCOM_ASTA_PRN }

