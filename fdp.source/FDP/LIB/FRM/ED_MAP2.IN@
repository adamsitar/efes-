procedure TMapa.GetEvent(var _Event: TEvent);
    begin
      inherited GetEvent(_Event);
      with _Event do
        case What of
          evKeyDown :
            case CO_ROBIT of
              robVYSTREDENIE: case Key of
                                kbEnter: SetCommand(_Event,cmVYSTRED);
                                kbEsc  : SetCommand(_Event,cmClose);
                                else if kbset_xy(Key) then ClearEvent(_Event)
                              end;
              robEDITOVANIE: case Key of
                                kbEnter     : SetCommand(_Event,Aky_Form);
                                kbDel       : SetCommand(_Event,cmZMAZBOD);
                                kbEsc       : SetCommand(_Event,cmUkoncit);
                                kbF1        : SetCommand(_Event,cmZemSurForm);
                                kbShiftF1   : SetCommand(_Event,cmLDMForm);
                                kbCtrlEnter : SetCommand(_Event,cmOK);
                                else if kbset_xy(Key) then ClearEvent(_Event)
                              end;
            else if Key = kbAltR then SetCommand(_Event,cmRefresh);
            end;
          evMouseClick:
            if (What = evMouseClick) and (inView(M.x,M.y)) then
               if bool(M.bt and mbLeftButton)  then
                  case CO_ROBIT of
                    robVYSTREDENIE: SetCommand(_Event,cmVYSTRED);
                    robEDITOVANIE : SetCommand(_Event,cmVLOZBOD);
                  end
               else if bool(M.bt and mbRightButton) then
                       case CO_ROBIT of
                         robVYSTREDENIE: SetCommand(_Event,cmClose);
                         robEDITOVANIE : SetCommand(_Event,cmRozdelit);{SetCommand(_Event,cmUkoncit);}
                       end
                     else if bool(M.bt and mbMiddleButton) then
                             case CO_ROBIT of
                               robVYSTREDENIE:;
                               robEDITOVANIE :SetCommand(_Event,cmRozdelit);
                             end;
      end;
    end;

procedure TMapa.HandleEvent(var _Event: TEvent);
    var DataPom  : PMapData;
        PMSurPom : PMapsur;
        btt      : byte;
        xr0,yr0,xr1,yr1: int;   {}
    const _Fill : bool = false;
    begin
     DataPom := PData; PMSurPom:= PMSur;
     if _Fill and not (_Event.Key in [kbLeft,kbRight,kbDown,kbUp,'+','-']) then
     begin
       FILLOVAT := true;
       _Fill  := false;
       Draw;
       if CO_ROBIT = robEDITOVANIE then writeCross;
     end;
     PData := Datapom; PMsur := PmSurPom;
      case _Event.What of
        evCommand :
          case _Event.Command of
            cmVYSTRED :   begin
                            m_cl;
                            with mouse_status.stat do
                              begin
                                get_m(x,y,bt);
                                Txx:= x; Tyy:= y;
                                Txxo := x; Tyyo :=y;
                                InvPoint(Xvystred,Yvystred);
                                btt:= 1;
                                xr0 := x;
                                xr1 := x;
                                yr0 := y;
                                yr1 := y;
                                SetWriteMode(XorPut);
                                while (bt=1) and not((btt<>1) {and TimeOut(tick,GetTicks,15)}) do
                                  begin
                                    get_m(x,y,btt);
                                    if (x<>Txx) then
                                      begin
                                        Rectangle(xr0,yr0,xr1,yr1);
                                        xr0 := Txxo-abs(Txxo-x);
                                        xr1 := Txxo+abs(Txxo-x);
                                        yr0 := Tyyo-trunc((Txxo-x)*0.8);
                                        yr1 := Tyyo+trunc((Txxo-x)*0.8);
                                        if yr1 > y1-10 then yr1 := y1-10;
                                        if yr1 < 10 then yr1 := 10;
                                        if yr0 > y1-10 then yr0 := y1-10;
                                        if yr0 < 10 then yr0 := 10;

                                        Rectangle(xr0,yr0,xr1,yr1);
                                      end;
                                    Txx:= x; Tyy:= y;
                                    Main0
                                  end;
                                if abs(xr1-xr0) > 10  then
                                      Rozsah := Rozsah*abs(Xr1-Xr0)/MaxX;
                              end;         {}
                            m_st;
                            SetWriteMode(0);
                            Draw;
                            PData := Map^.DejPrvek(DataPom);
                            Exit
                          end;

            cmVLOZBOD: if (Txx <> xc) or (Tyy <> yc) then
                           DrawInsVect;

            cmZMAZBOD: Delete_Point;
            cmZemSurForm: begin
                            Aky_Form := cmZemSurForm;
                            formular_ZemSur(_Event);
                            if _Event.Command = cmOK then
                              DrawInsVect
                          end;
            cmLDMForm   : begin
                            Aky_Form := cmLDMForm;
                            formular_LDM(_Event);
                            if _Event.Command = cmOK then
                              DrawInsVect
                          end;

            cmUKONCIT   : begin
                            Ask(_Event,cmQuit, ' Varovanie ','Ukoncit editovanie ?',White,clBUTTON_COLOR,waitASK*18);
                            if isCommand(_Event,cmQuit) then
                                begin
                                 SetCommand(_Event,cmClose);
                                 Exit
                                end;
                          end;
            cmRozdelit  : Rozdelit_Ciaru;
            else Exit
          end;
        evKeyDown :
          if not (_Event.Key in setkbPreMapy) then Exit
          else begin
                 case _Event.Key of
                   '+'    : Rozsah:= Rozsah+Vy_r(Rozsah);
                   '-'    : Rozsah:= Rozsah-Vy_r(Rozsah);
                   kbLeft : Stred(Xvystred-Vy_r(Rozsah),Yvystred);
                   kbRight: Stred(Xvystred+Vy_r(Rozsah),Yvystred);
                   kbDown : Stred(Xvystred,Yvystred-Vy_r(Rozsah));
                   kbUp   : Stred(Xvystred,Yvystred+Vy_r(Rozsah));
                  end;
                  if CO_ROBIT = robEDITOVANIE then
                  case _Event.Key of
                   kbCtrlLeft,
                   kbCtrlRight: Select_Point(_Event.Key);
                   kbIns  :  Insert_point;
                   'Z','z':  Zaciatok_ciary;
                   'K','k':  Kruhovy_obluk;
                   'R','r':  begin
                               Draw;
                               PData := Map^.DejPrvek(DataPom);
                               PMSur := PData^.SVMap^.DejPrvek(PMSurPom);
                               writecross;
                             end;

                 end;
                 if (_Event.Key in [kbLeft,kbRight,kbDown,kbUp,'+','-']) then
                   begin
                     if FILLOVAT then
                      begin
                        FILLOVAT := false;
                        _Fill := true;
                        Draw;{Kresli(false){Draw ak nie je Xor}
                        if CO_ROBIT = robEDITOVANIE then writeCross;
                      end
                     else Kresli(false);
                     PData := Map^.DejPrvek(DataPom);
                     if PData^.SVMap <> nil then
                        PMSur := PData^.SVMap^.DejPrvek(PMSurPom);
                   end;
                 if CO_ROBIT = robEDITOVANIE then Cross;
               end;
         else Exit;
      end;
      ClearEvent(_Event)
    end;

