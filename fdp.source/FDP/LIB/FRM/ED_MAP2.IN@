procedure TMapa.SaveMapOrSymbol(_Data: PMapData);
    var    res:Integer;

         { SymbolF : file of tSymbol;}
          SuradnF : file of Suradnica;
          SymF    : file of tSymbol;
          DirInfo : SearchRec;
          stmap   : string;
          sym     : tSymbol;
          sur     : suradnica;

Begin
    with _Data^ do
    If  not MapSym Then { symboly }
      begin
        if SVSym = Nil then Exit;
        Assign(SymF,PathToMaps+MapNaz);
        Rewrite(SymF);
        if SVSym^.DejPocet = 0 then
        begin
          Close(SymF);
          Erase(SymF);
          Exit;
        end;

        SVSym^.JdiNaZacatek;
        repeat
          PMSym := SVSym^.DejAktPrvek;
          if PMSym=nil then break;
          Sym.Ts  := PMSym^.Ts;
          Sym.Xzs := PMSym^.Xzs;
          Sym.Yzd := PMSym^.Yzd;
          Sym.Vet := PMSym^.Vet;
          System.Write(SymF,Sym);
          SVSym^.JdiNaDalsi(Konec)
        until Konec;

        for res := 0 to sizeof(MapSpec)-1 do MapSpec[res] := 0;
        if MapKr Then  MapSpec[0] :=   0
        else  MapSpec[0] :=  255;
        MapSpec[2] := MapCl;
        MapSpec[3] := MapTyp;
        MapSpec[4] := byte(MapFill);
        MapSpec[5] := MapPrior;
        MapSpec[6] := 0;
        MapSpec[7] := TypCiar;

        MapSpec[11]:= day;
        MapSpec[12]:= month;
        if year < 2000 then MapSpec[13]:= year-1900
        else MapSpec[13]:= year-2000;
        Move(MapSpec,Sym,Sizeof(MapSpec));
        System.Write(SymF,Sym);
        Close(SymF);
      end
      else
      begin           { mapy }
        if SVMap = nil Then Exit;
        Assign(Suradnf,PathToMaps+MapNaz);
        Rewrite(Suradnf);

        if SVMap^.DejPocet = 0 then
        begin
          Close(SuradnF);
          Erase(SuradnF);
          Exit;
        end;

        SVMap^.JdiNaZacatek;
        repeat
          PMSur := SVMap^.DejAktPrvek;
          if PMSur=nil then break;
          Sur.Ts  := PMSur^.Ts;
          Sur.Xzs := PMSur^.Xzs;
          Sur.Yzd := PMSur^.Yzd;
          System.Write(SuradnF,sur);
          SVMap^.JdiNaDalsi(Konec)
        until Konec;

        for res := 0 to sizeof(MapSpec)-1 do MapSpec[res] := 0;
        if MapKr Then  MapSpec[0] :=   0
        else  MapSpec[0] :=  255;
        MapSpec[2] := MapCl;
        MapSpec[3] := MapTyp;
        if MapFill>0 Then
        begin
          MapSpec[4] :=   MapFill;
          MapSpec[6] := MapPor;    { bolo maptyp }
        end
        else
        begin
          MapSpec[4] :=  0;
          MapSpec[6] :=  0;
        end;
        MapSpec[5] := MapPrior;
        MapSpec[7] := TypCiar;
        MapSpec[11]:= day;
        MapSpec[12]:= month;
        if year < 2000 then MapSpec[13]:= year-1900
        else MapSpec[13]:= year-2000;
        Move(MapSpec,Sur,Sizeof(MapSpec));
        System.Write(Suradnf,sur);
        Close(SuradnF);
      end;
End; { SaveMapOrSymbol }


procedure TMapa.FarbaMap(coho : int);
var   _Event: TEvent;
    begin
      if USER_PRIORITY = 0 then
      begin
        Err('NemĀte prĀva na zmenu farieb');
        Exit;
      end;
      if coho = cmPOVfarby then
      begin
        Map^.JdiNaZacatek;
        repeat
          PData := Map^.DejAktPrvek;
          case  PData^.MapTyp  of
             1: PData^.Mapcl:= clOBM;
             2: PData^.Mapcl:= clNEB;
             3: PData^.Mapcl:= clCTR;
             4: PData^.Mapcl:= clTMA;
             5: PData^.Mapcl:= clLET;
             6: PData^.Mapcl:= clSTH;
             7: PData^.Mapcl:= clROZ;
             8: PData^.Mapcl:= clNAV;
             9: PData^.Mapcl:= clCIV;
          end;
          Map^.JdiNaDalsi(Konec);
        until Konec;
      end
      else
      begin
        formular_Farba(_Event);
        if not isCommand(_Event, cmOK) then Exit;
        Map^.JdiNaZacatek;
        repeat
          PData := Map^.DejAktPrvek;
          if coho-cmFARBA = PData^.MapTyp then begin
            PData^.Mapcl:= MapFarba;
            SaveMapOrSymbol(PData);
          end;
          Map^.JdiNaDalsi(Konec);
        until Konec;
      end;
      Draw;
    end;


