 procedure _codeDBT_ZAM(ZAM: PZAM; buff: PDB_buff; desc: PDB_head);
     var   s : string;
     begin
       str_toDBstr(code_ZAM_data(ZAM),buff^[db_ZAM_data]);
       str_toDBstr(strpas(ZAM^.pozn),buff^[db_ZAM_18]);
       str_toDBstr(code_ZAM_19(ZAM,true),buff^[db_ZAM_19]);
       s:= '' {$IFDEF NET} + icao_ARR + rectostr(ZAM^.rec) {$ENDIF};
       str_toDBstr(s,buff^[db_ZAM_ine])
     end;

 procedure _decodeDBT_ZAM(buff: PDB_buff; ZAM: PZAM; desc: PDB_head);
     var   res, s,t : string;
           i : int;
     begin
       fillchar(ZAM^,sizeof(ZAM^),0);

       decode_ZAM_data (DBstr_to_str (buff^[db_ZAM_data]), ZAM, res,false);
       ZAM^.pozn:= strpasnew(DBstr_to_str (buff^[db_ZAM_18]));
       decode_ZAM_19 (DBstr_to_str (buff^[db_ZAM_19]), ZAM);

       s:= DBstr_to_str (buff^[db_ZAM_ine]); i:= 1;
       {$IFDEF NET} strtorec(getstr(s,i,[icao_ARR]), ZAM^.rec);
       {$ENDIF}

       {format_ZAM(ZAM);}
     end;

