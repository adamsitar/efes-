 procedure _codeDB0_ZAM(ZAM: PZAM; buff: PDB_buff; desc: PDB_head); far;
     var   s : string;
     begin
       s:= code0_ZAM_(ZAM);
       {$IFDEF NET} s:= s+KON_SPR+rectostr(ZAM^.rec); {$ENDIF}
       Move(buff^[0],s[0],ord(buff^[0][0])+1);
     end;

 procedure _decodeDB0_ZAM(buff: PDB_buff; ZAM: PZAM; desc: PDB_head); far;
     var   s : string;
     begin
       Move(buff^[0],s[0],ord(buff^[0][0])+1);
       decode0_ZAM_(s, ZAM);
       {$IFDEF NET}
        strtorec(getstr(s,2,[KON_SPR]), ZAM^.rec);
       {$ENDIF}
     end;


