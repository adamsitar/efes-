 procedure decode0DB_FPL4(buff: PDB_buff; FPL: PFPL4); far;
     var   s,t : string;
           p   : int;
     begin
       decode0_FPL4_h (DBstr_to_str(buff^[0]),FPL);

       s:= DBstr_to_str (buff^[1]);
       FPL^._15:= decode_line_i (copy(s,2,length(s)-1), FPL^._15,[]);
       FPL^._15:= decode_line_i (DBstr_to_str(buff^[2]),FPL^._15,[]);

       s:= DBstr_to_str(buff^[3]);
