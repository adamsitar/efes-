       t:= getstr(s,p,[kbCRLF]);
       FPL^._19:= decode_line_i (copy(t,2,length(t)-1),FPL^._19,[]); inc(p);

       s:= DBstr_to_str(buff^[6]);
       FPL^._20:= decode_line_i (copy(s,2,length(s)-1),FPL^._20,[]);

       format_FPL4(FPL)
     end;
*)


{ ------------------------
   kodovanie/de... prenos
  ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
}
 procedure code0_FPL4(FPL: PFPL4; var pkt: TNETpkt);
     var   s : array[1..6] of string;
           p : word;
     begin
       s[1]:= icao_STD + code0_FPL4_1(FPL)+kbCRLF; p:= length(s[1]);
       s[2]:= code0_FPL4_2(FPL)+kbCRLF; inc(p,length(s[2]));
       s[3]:= code0_FPL4_3(FPL)+kbCRLF; inc(p,length(s[3]));
       s[4]:= code0_FPL4_4(FPL)+kbCRLF; inc(p,length(s[4]));
       s[5]:= code0_FPL4_5(FPL)+kbCRLF; inc(p,length(s[5]));
       s[6]:= code0_FPL4_6(FPL)+kbCRLF+ icao_END; inc(p,length(s[6]));
              

       if not new_NETpkt_data (nil,p, pkt.pkt) then Exit;
       move(s[1][1],pkt.pkt.data^[0],length(s[1])); p:=   length(s[1]);
       move(s[2][1],pkt.pkt.data^[p],length(s[2])); inc(p,length(s[2]));
       move(s[3][1],pkt.pkt.data^[p],length(s[3])); inc(p,length(s[3]));
       move(s[4][1],pkt.pkt.data^[p],length(s[4])); inc(p,length(s[4]));
       move(s[5][1],pkt.pkt.data^[p],length(s[5])); inc(p,length(s[5]));
       move(s[6][1],pkt.pkt.data^[p],length(s[6])); inc(p,length(s[6]));
     end;

 procedure decode0_FPL4(const pkt: TNETpkt; FPL: PFPL4);
     var   s : string;
     begin
       decode0_FPL4_1(get_str(pkt.pkt.data,pkt.pkt.dlz,1,[kbCRLF],sizeof(string)-1), FPL);
       decode0_FPL4_2(get_str(pkt.pkt.data,pkt.pkt.dlz,2,[kbCRLF],sizeof(string)-1), FPL);
       decode0_FPL4_3(get_str(pkt.pkt.data,pkt.pkt.dlz,3,[kbCRLF],sizeof(string)-1), FPL);
       decode0_FPL4_4(get_str(pkt.pkt.data,pkt.pkt.dlz,4,[kbCRLF],sizeof(string)-1), FPL);
       decode0_FPL4_5(get_str(pkt.pkt.data,pkt.pkt.dlz,5,[kbCRLF],sizeof(string)-1), FPL);
       decode0_FPL4_6(get_str(pkt.pkt.data,pkt.pkt.dlz,6,[kbCRLF],sizeof(string)-1), FPL);
       _dec_18 (FPL^._18,rmk_DATE);

       {$IFDEF NET}
         rec_data(pkt.ods, FPL^.rec);
       {$ENDIF}

       _decode_FPL4 (FPL^,false,s); { kvoli urceniu EET }
     end;

