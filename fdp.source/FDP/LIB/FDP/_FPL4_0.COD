{
  Aby som minimalizoval cas kodovania a nacitania dat,
  vyhol som sa funkciam odfiltrujucim riadiace znaky (icao_NXIT)
  a pocitam s pevnoou polohou riadku a jeho zaciatku,
  pri kodovani pchar na celu polozku sa pridava ' ' a pri dekodovani ubera ' '
  Predpoklada sa, ze pchar-y su odalokovane.
}

{ ------------------------
   kodovanie/de...
  ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
}
 function code0_1(p: pchar): string;
    var   s : string;
    begin
      s[0]:= chr(minimum(strlen(p),minimum(sizeof(string)-1,DB_riadok-2)));
      move(p[0],s[1],ord(s[0]));
      code0_1:= icao_ARR+cut_(s)+' '
    end;

 function code0_2(p: pchar): string;
    var   s     : string;
          l1,l2 : int;
    begin
      l1:= strlen(p);
      l2:= l1-(DB_riadok-2);
      if l2>0 then
         begin
           s[0]:= chr(minimum(l2,minimum(sizeof(string)-1,DB_riadok-2)));
           move(p[DB_riadok-2],s[1],ord(s[0]))
         end
      else s:= '';
      code0_2:= ' '+cut_(s)+' '
    end;

 function decode0_i(s: string; p: pchar): pchar;
    begin
      decode0_i:= StrNPCopy(p, cut_(copy(s,2,length(s)-1)), true, true)
    end;

 function code0_FPL4_1(FPL: PFPL4): string;
    var   s1,s2: string;
    begin
      with FPL^ do
        begin
          s2:=            + format_s(_7)
               + icao_ARR + format_s(_8)
               + icao_ARR + format_s(_9)
               + icao_ARR + format_s(_10)

               + icao_ARR + format_s(_13)
               + icao_ARR + format_s(_16)
               + icao_ARR + format_s(_14)
               + icao_ARR + format_s(strpas(_17));
        end;

      code0_FPL4_1:= s2
    end;

 procedure decode0_FPL4_1(s: string; FPL: PFPL4);
     var   t : string;
           _sec : byte;
     begin
       fillchar(FPL^,sizeof(FPL^),0);
       with FPL^ do
         begin
           _7 := cut_(getstr(s,1,odd_ICAO));
           _8 := cut_(getstr(s,2,odd_ICAO));
           _9 := cut_(getstr(s,3,odd_ICAO));
           _10:= cut_(getstr(s,4,odd_ICAO));

           _13:= cut_(getstr(s,5,odd_ICAO));
           _16:= cut_(getstr(s,6,odd_ICAO));
           _14:= cut_(getstr(s,7, odd_ICAO));

           { vynechane zamerne pri konverzii
             t:= cut_(getstr(s,8,odd_ICAO));
             if t<>'' then _17:= strpasnew(t);
           }
         end
     end;


 function code0_FPL4_2(FPL: PFPL4): string;
    begin
      code0_FPL4_2:= code0_1(FPL^._15)
    end;

 procedure decode0_FPL4_2(s: string; FPL: PFPL4);
     begin
       FPL^._15:= decode0_i(s,FPL^._15);
     end;

 function code0_FPL4_3(FPL: PFPL4): string;
    begin
      code0_FPL4_3:= code0_2(FPL^._15)
    end;

 procedure decode0_FPL4_3(s: string; FPL: PFPL4);
     begin
       FPL^._15:= decode0_i(s,FPL^._15);
     end;


 function code0_FPL4_4(FPL: PFPL4): string;
    begin
      code0_FPL4_4:= code0_1(FPL^._18)
    end;

 procedure decode0_FPL4_4(s: string; FPL: PFPL4);
     begin
       FPL^._18:= decode0_i(s,FPL^._18);
     end;

 function code0_FPL4_5(FPL: PFPL4): string;
    begin
      code0_FPL4_5:= code0_2(FPL^._18)
    end;

 procedure decode0_FPL4_5(s: string; FPL: PFPL4);
     begin
       FPL^._18:= decode0_i(s,FPL^._18);
     end;


 function code0_FPL4_6(FPL: PFPL4): string;
    begin
      code0_FPL4_6:=   icao_ARR + DateToStr (FPL^.date.d,FPL^.date.m,FPL^.date.r,0,'')
                     + icao_NXT + TimeToStr (FPL^.eet.h,FPL^.eet.m{_eet.s},'')
                     + icao_ARR + FPL^.stat

                     + icao_ARR + format_s(strpas(FPL^._5))

                     + icao_ARR + format_s(strpas(FPL^._20))
    end;

 procedure decode0_FPL4_6(s: string; FPL: PFPL4);
     var   t: string;
           _sec: byte;
     begin
       t:= getstr(s,1,odd_ICAO);
       GetDateStr(FPL^.date.r,FPL^.date.m,FPL^.date.d, getstr(t,1,[icao_NXT]), false);
       GetTimeStr(FPL^.eet.h,FPL^.eet.m,_sec, getstr(t,2,[icao_NXT]));

       t:= getstr(s,2,odd_ICAO);
       FPL^.stat:= getstr(t,1,[#255]);
       {$IFDEF NET}
        strtorec(getstr(t,2,[#255]),FPL^.rec);
       {$ENDIF}

       {FPL^._5 := StrPasNew(getstr(s,3,odd_ICAO));
       FPL^._20:= StrPasNew(getstr(s,4,odd_ICAO))}
     end;

 { 7. riadok uz z archivu nepotrebujem
 }


{ ------------------------
   kodovanie/de... pre DB
  ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
}
 procedure _codeDB0_FPL4(FPL: PFPL4; buff: PDB_buff; head: PDB_head); far;
     var   s : string;
     begin
       str_toDBstr(code0_FPL4_1(FPL),buff^[0]);
       str_toDBstr(code0_FPL4_2(FPL),buff^[1]);
       str_toDBstr(code0_FPL4_3(FPL),buff^[2]);
       str_toDBstr(code0_FPL4_4(FPL),buff^[3]);
       str_toDBstr(code0_FPL4_5(FPL),buff^[4]);
       s:= code0_FPL4_6(FPL);
       {$IFDEF NET}
         s:= s + ODD_SPR + rectostr(FPL^.rec);
       {$ENDIF}
       str_toDBstr(s,buff^[5]);
     end;

 procedure _decodeDB0_FPL4(buff: PDB_buff; FPL: PFPL4; head: PDB_head); far;
     var   s : string;
     begin
       decode0_FPL4_1(DBstr_to_str(buff^[0]),FPL);
       decode0_FPL4_2(DBstr_to_str(buff^[1]),FPL);
       decode0_FPL4_3(DBstr_to_str(buff^[2]),FPL);
       decode0_FPL4_4(DBstr_to_str(buff^[3]),FPL);
       decode0_FPL4_5(DBstr_to_str(buff^[4]),FPL);
       decode0_FPL4_6(DBstr_to_str(buff^[5]),FPL);
       _dec_18 (FPL^._18,rmk_DATE);
     end;


(*
