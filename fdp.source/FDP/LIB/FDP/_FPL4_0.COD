       FPL^._19:= decode_line_i (copy(s,2,length(s)-1), FPL^._19,[]);

       s:= get_str(pkt.pkt.data,pkt.pkt.dlz,7,[kbCRLF],sizeof(string)-1);
       FPL^._20:= decode_line_i (copy(s,2,length(s)-2), FPL^._20,[]);

       {$IFDEF NET}
         rec_data(pkt.ods, FPL^.rec);
       {$ENDIF}
     end;
