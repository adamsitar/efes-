 { ---------------------
   kodovanie pre DB
   ---------------------
 }

 {$I _DVZ_DB.cod}

 procedure codeDB_DVZ (DVZ: PDVZ; buff: PDB_buff; desc: PDB_head);
     begin
       if desc^.attr and DBbin <> 0 then _codeDBB_DVZ(DVZ,buff,desc)
       {$IFDEF OPL} else if desc^.attr and DBtxt = 0 then _codeDBT_DVZ(DVZ,buff,desc) {$ENDIF}
       else _codeDBT_DVZ(DVZ,buff,desc)
     end;

 procedure decodeDB_DVZ(buff: PDB_buff; DVZ: PDVZ; desc: PDB_head);
     begin
       fillchar(DVZ^,sizeof(DVZ^),0);
       if desc^.attr and DBbin <> 0 then _decodeDBB_DVZ(buff,DVZ,desc)
       {$IFDEF OPL} else if desc^.attr and DBtxt = 0 then _decodeDB0_DVZ(buff,DVZ,desc) {$ENDIF}
       else _decodeDBT_DVZ (buff,DVZ,desc);
     end;



 { ---------------------
   kluc
   ---------------------
 }

 function codekey_DVZ(DVZ: PDVZ): string;
    begin
      codekey_DVZ:=   mtks_rus_to_lat(upstring(
                                   format_s(_mairbase(DVZ^.pre))
                      + icao_NXT + format_s(_mairbase(DVZ^.kym))
                      + icao_ARR + code_l4_date(DVZ^.date)
                      + icao_ARR + code_l4_datums(DVZ^.dap)
                      ))
    end;

 procedure decodekey_DVZ(key: string; DVZ: PDVZ);
     var   s: string;
     begin
       fillchar(DVZ^,sizeof(DVZ^),0);
       s:= getstr(key,1,[icao_ARR]);
       DVZ^.pre:= getstr(s,1,[icao_NXT]);
       DVZ^.kym:= getstr(s,2,[icao_NXT]);
       decode_l4_date(getstr(key,2,[icao_ARR]),DVZ^.date);
       decode_l4_datum(getstr(key,3,[icao_ARR]),DVZ^.dap)
     end;

 {
 function codekey_DVZ_RPL(DVZ: PDVZ): string; far;
    begin
      codekey_DVZ_RPL:= codekey_DVZ(DVZ) + icao_ARR + code_l4_datums(DVZ^.dap)
    end;

 procedure decodekey_DVZ_RPL(s: string; DVZ: PDVZ); far;
     begin
       decodekey_DVZ(s,DVZ);
       decode_l4_datum(getstr(s,3,[icao_ARR]),DVZ^.dap)
     end;
 }