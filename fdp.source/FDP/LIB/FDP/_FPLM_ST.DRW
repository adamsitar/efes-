                       begin
                         if _1<_2 then ch:= '' else ch:= '';
                         s:= s+ch
                       end
                  end;
               {$IFNDEF EDD_20} if miniSTRIP<>mini_strip then dy:= y1 else dy:= y+dy03;
               {$ELSE}         dy:= y1;
               {$ENDIF}
               outtextxy(x0+dx,dy,s);*)


               (* Takto to bolo do 8,10 po zasah v UA na r. 238
               if miniSTRIP=mini_strip then
                  begin
