  procedure draw_mFPLtrgt(p: pointer; x,y: int; var sur: Tsur; maz: bool);
     var    s: string[1];
     begin
       s:= PDmFPL(p)^.ssr_;
       if s<>'' then s:= s[1];
       draw_trgt(code_FPLM_7a(p),s+PDmFPL(p)^.ssr, x,y,sur, maz, cl_mFPL)
     end;

  procedure draw_oFPLtrgt(p: pointer; x,y: int; var sur: Tsur; maz: bool);
     var    s: string[1];
     begin
       s:= PDmFPL(p)^.ssr_;
       if s<>'' then s:= s[1];
       draw_trgt(code_FPLM_7a(p),s+PDmFPL(p)^.ssr, x,y,sur, maz, cl_oFPL)
     end;
{$ENDIF}


