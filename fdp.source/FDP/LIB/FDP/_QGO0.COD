function code0_QGO_1(QGO: PQGO): string;
   var   s : string;
         i : int;
   begin
     with QGO^ do
       begin
         s:=   ZAC_SPR + format_s(kod)
             + ODD_SPR + ' ' {IntToStr(cis,3,0)}
             + ODD_SPR + format_s(get_line_i(stav,1))
             + ODD_SPR + format_s(get_line_i(stav,2))
       end;
     code0_QGO_1:= s
   end;

function code0_QGO_2(QGO: PQGO): string;
   var   s,t : string;
         i : int;

   begin
     with QGO^ do
       begin
         s:=  ODD_SPR + format_s(TQGO)
             +ODD_SPR + format_s(strpas(TQGO_))
             +ODD_SPR + code0_utc(QGO^.TQGOc);

         s:= s+ODD_SPR + format_s(MQGO)
             +ODD_SPR + format_s(strpas(MQGO_))
             +ODD_SPR + code0_utc(QGO^.MQGOc);

         s:= s+ODD_SPR + DateToStr(date.d,date.m,date.r,0,'')
             +ODD_SPR + code0_stat(format_s(stat))
             +KON_SPR;

       end;
     code0_QGO_2:= s
   end;


procedure decode0_QGO_1(s: string; QGO: PQGO);
    var   i,ii : int;
    begin
      fillchar(QGO^,sizeof(TQGO),0);
      with QGO^ do
        begin
          kod  := GetStr(s,1,setLET_1_1);
         {cis  := GetInt(s,2,setLET_1_1);}

          stav := strpasnew(getstr(s,3,setLET_1_1) + kbNL_ + getstr(s,4,setLET_1_1));
        end
    end;

procedure decode0_QGO_2(s: string; QGO: PQGO);
    var   t: string;
    begin
      with QGO^ do
        begin
          TQGO:= replchar(cut_(getstr(s,1,setLET_1_1)),[icao_ARR],icao_NXIT);
          TQGO_ := strpasnew(getstr(s,2,setLET_1_1));
          TQGOc:= decode0_utc(getstr(s,3,setLET_1_1));

          MQGO:= replchar(cut_(getstr(s,4,setLET_1_1)),[icao_ARR],icao_NXIT);
          MQGO_ := strpasnew(getstr(s,5,setLET_1_1));
          MQGOc:= decode0_utc(getstr(s,6,setLET_1_1));

          GetDateStr(date.r, date.m,date.d, GetStr(s,7,setLET_1_1),false);
          stat := decode0_stat(GetStr(s,8,setLET_1_1));

          datum_init (dap, date.d,date.m,date.r,0,0,0);
        end
    end;


{ ---------------------
  prenos
  --------------------- }

procedure code0_QGO(QGO: PQGO; var pkt: TNETpkt); far;
    var   s1,s2 : string; p : word;
    begin
      s1:= code0_QGO_1(QGO);
      s2:= code0_QGO_2(QGO);

      if not new_NETpkt_data (nil,length(s1)+length(s2), pkt.pkt) then Exit;
      move(s1[1],pkt.pkt.data^[0],length(s1)); p:= length(s1);
      move(s2[1],pkt.pkt.data^[p],length(s2))
    end;

procedure decode0_QGO(const pkt: TNETpkt; QGO: PQGO);
    var   s  : string;
          ii : int;
    begin
      ii:= pkt_split(pkt.pkt, 4);

      s:= init_str(@pkt.pkt.data^[0],ii);
      decode0_QGO_1(s, QGO);

      s:= init_str(@pkt.pkt.data^[ii],pkt.pkt.dlz-ii+1);
      decode0_QGO_2(s, QGO)

      {$IFDEF NET};
        rec_data(pkt.ods, QGO^.rec);
      {$ENDIF}
    end;


{ ---------------------
  kluc
  --------------------- }

procedure decode0key_QGO(s: string; QGO: PQGO); far;
    begin
      fillchar(QGO^,sizeof(QGO^),0);
      with QGO^ do
        begin
          kod := getstr(s,1,setLET_1_1);
         {cis := getint(s,2,setLET_1_1);}
          GetDateStr(date.r,date.m,date.d, getstr(s,3,setLET_1_1),false)
        end
    end;
