 function najdi_dep (const FPL: DFPL4; const FDR: DFDR): string;
    var   dep  : string;
    begin
      dep:= '';
      if FDR.dep.kod<>ZZZZ then dep:= FDR.dep.kod;
      if (dep=ZZZZ) or (dep='') then dep:= _item_18(FPL._18,rmk_DEP,1);
      najdi_dep:= dep
    end;

 function najdi_arr(const FPL: DFPL4; const FDR: DFDR): string;
    var   arr  : string;
    begin
      arr:= '';
      if FDR.arr.kod<>ZZZZ then arr:= FDR.arr.kod
      else arr:= copy(getstr(FPL._16,2,[icao_NXIT]),1,kod_AP);
      if (arr=ZZZZ) or (arr='') then arr:= copy(getstr(FPL._16,3,[icao_NXIT]),1,kod_AP);
      if (arr=ZZZZ) or (arr='') then
         begin
           arr:= _item_18(FPL._18,rmk_DEST,1);
           if (arr=ZZZZ) or (arr='') then arr:= _item_18(FPL._18,rmk_ALTN,1);
         end;
      najdi_arr:= arr
    end;
