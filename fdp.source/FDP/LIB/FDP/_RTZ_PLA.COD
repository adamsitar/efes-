 { ------------------------------------------------------

   Priklad : (RTZ                      ; pole  3
              -id                      ; letisko
              -date                    ; datum platnosti
              -data                    ; popis stavu letiska
             )
 }


 { ---------------------
   kodovanie pre prenos
   ---------------------
 }

 procedure code_RTZ(RTZ: PRTZ; var pkt: TNETpkt);
     var   pch,p : pchar;
     begin
       pch:= StrPasNew(   icao_STD + hd_RTZ
                        + icao_ARR + codekey_RTZ(RTZ)
                        + icao_ARR
                      );
       p:= l4_format_p(RTZ^.data);
       pch:= StrNCopy (pch,p,true,false);
       pch:= StrNPCopy (pch,icao_END, true,true);
       new_NETpkt_data (pchars(pch),strlen(pch), pkt.pkt);
       strdispose(pch)
     end;

 procedure decode_RTZ(const pkt: TNETpkt; RTZ: PRTZ);
     var   zac,kon : word;
           poc : int;
           p   : pchar;
     begin
       {fillchar(RTZ^,sizeof(RTZ^),0); -> decodekey... }
       decodekey_RTZ(get_strs0p(pkt.pkt.data,pkt.pkt.dlz, 2,3, [icao_ARR]),RTZ);
       {$IFDEF NET}
         rec_data(pkt.ods, RTZ^.rec);
       {$ENDIF}
       get_ind (pkt.pkt.data,pkt.pkt.dlz,4,[icao_ARR], zac,kon);
       poc:= N(pkt.pkt.dlz-zac-1);
       if poc=0 then Exit;
       RTZ^.data:= StrAlloc (poc);
       move(pkt.pkt.data^[zac],RTZ^.data[0],poc);
     end;



 { ---------------------
   kodovanie pre DB
   ---------------------
 }

 procedure codeDB_RTZ (RTZ: PRTZ; buff: PDB_buff; desc: PDB_head);
     var   p1,p2 : int;
           s : string;
     begin
       str_toDBstr(codekey_RTZ(RTZ),buff^[db_RTZ_id]);

       p1:= minimum(DB_riadok,strlen(RTZ^.data));
       buff^[db_RTZ_data1][0]:= chr(p1);
       move(RTZ^.data[0],buff^[db_RTZ_data1][1],p1);

       p2:= minimum(DB_riadok,N(strlen(RTZ^.data)-p1));
       buff^[db_RTZ_data2][0]:= chr(p2);
       move(RTZ^.data[p1],buff^[db_RTZ_data2][1],p2);

       s:= '' {$IFDEF NET} + icao_ARR + rectostr(RTZ^.rec) {$ENDIF};
       str_toDBstr(s,buff^[db_RTZ_ine])
     end;


 procedure decodeDB_RTZ(buff: PDB_buff; RTZ: PRTZ; desc: PDB_head);
     var   s: string;
     begin
       fillchar(RTZ^,sizeof(RTZ^),0);

       decodekey_RTZ(DBstr_to_str(buff^[db_RTZ_id]),RTZ);
       RTZ^.data:= strpasnew(DBstr_to_str (buff^[db_RTZ_data1]));
       RTZ^.data:= strNPcopy(RTZ^.data,DBstr_to_str (buff^[db_RTZ_data2]),true,true);

       s:= DBstr_to_str (buff^[db_RTZ_ine]);
       {$IFDEF NET} strtorec(getstr(s,1,[icao_ARR]), RTZ^.rec);
       {$ENDIF}

       format_RTZ(RTZ);
     end;


 { ---------------------
   kluc
   ---------------------
 }

 function codekey_RTZ(RTZ: PRTZ): string;
    begin
      codekey_RTZ:=                mtks_rus_to_lat(RTZ^.id)
                      + icao_ARR + code_l4_date(RTZ^.date)
    end;

 procedure decodekey_RTZ(key: string; RTZ: PRTZ);
     begin
       fillchar(RTZ^,sizeof(RTZ^),0);
       RTZ^.id:= getstr(key,1,[icao_ARR]);
       decode_l4_date(getstr(key,2,[icao_ARR]),RTZ^.date);
     end;
