*)

 function _item_22 (p22: pchar; sITEM: string): pchar;
    var   p0,pn,pi,item,pITEM : pchar;
          eop22 : bool;
          litem : word;
          s,t : string;
          i : int;

    begin
      _item_22:= nil;

     { vyhladanie ukazovatela na zaciatok sekvencie pola
       item/.... v poradi uvedenom ind-exom
     }
      s:= sITEM+icao_NXT+NULL;
      item:= @s[1];
      litem:= strlen(item);
      p0:= _item_l4(p22,item);
      if (p0=nil) then Exit;

      incptr(pointer(p0),litem);


     { vyhladanie zaciatku ostatnych poli,
       zacinaju po mezere, slove z mnoziny "arrayFPL4" a lomke
     }
      eop22:= false; pn:= p0;
      while not eop22 do
       begin
         pn:= strpos(pn,icao_NXIT);   { najdenie zaciatku dalsieho slova item/xxx slovo }
         if pn<>nil then
            begin
              t:= getpstr(pn,1,[icao_NXIT]);  { je to klucove slovo s lomkou ? }
              if pos(icao_NXT,t)>0 then
                 begin
                   t:= getstr(t,1,[icao_NXT]);
                   i:= 0; while (i<max_arrayFPL4) and (t<>arrayFPL4[i]) do inc(i);
                   if i<max_arrayFPL4 then eop22:= true
                   else if pn[0]=icao_NXIT then incptr(pointer(pn),1)
                 end 
              else incptr(pointer(pn),1)
            end
         else eop22:= true;
       end;

     { nacitanie pola
     }
      if pn<>nil then litem:= pn-p0 else litem:= strlen(p0);
      pITEM:= StrAlloc(litem);
      strLcopy(pITEM,p0,litem);
      _item_22:= pITEM;
    end;


 function _item_22_is (p22: pchar; sITEM: string; var item: string; item_size: byte): bool;
    var   p,pi : pchar;
    begin
      pi:= _item_22 (p22, sITEM);
      if pi<>nil then
         begin
           item:= copy(strpas(pi),1,item_size);
           strdispose(pi);
           _item_22_is:= true
         end
      else _item_22_is:= false
    end;

 function _item_22_ip (p22: pchar; sITEM: string; var item: pchar): bool;
    var   p,pi : pchar;
    begin
      pi:= _item_22 (p22, sITEM);
      if pi<>nil then
         begin
           strdispose(item);
           item:= pi;
           _item_22_ip:= true
         end
      else _item_22_ip:= false
    end;


 function _decode_FPL4_22(var FPL: DFPL4; var res: string): bool;
    var   bres : bool;
          p : pchar;
    begin
      res:= '';

     {$IFDEF A36YKA} p:= mtkp_rus_to_lat(FPL._22,true)
     {$ELSE}         p:= FPL._22
     {$ENDIF};

      bres:= _item_22_is(p, a_8, FPL._8,  sizeof(FPL._8)-1);
      bres:= _item_22_is(p, a_9,  FPL._9,  sizeof(FPL._9)-1)  or bres;
      bres:= _item_22_is(p, a_10, FPL._10, sizeof(FPL._10)-1) or bres;
      bres:= _item_22_is(p, a_13, FPL._13, sizeof(FPL._13)-1) or bres;
      bres:= _item_22_is(p, a_14, FPL._14, sizeof(FPL._14)-1) or bres;
      bres:= _item_22_ip(p, a_15, FPL._15) or bres;
      bres:= _item_22_is(p, a_16, FPL._16, sizeof(FPL._16)-1) or bres;
      bres:= _item_22_ip(p, a_18, FPL._18) or bres;
      bres:= _item_22_ip(p, a_19, FPL._19) or bres;

      _decode_FPL4_22:= bres;

     {$IFDEF A36YKA} strdispose(p);
     {$ENDIF}

      if not bres then l4_err(a_22,'',0,err_22_,res);
    end;
