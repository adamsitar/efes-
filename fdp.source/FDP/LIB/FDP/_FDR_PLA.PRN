{$IFDEF PRN}
 function print_FDR(FDR: PFDR): bool;
    begin
      print_FDR:= print_str(PortNo,code_FDR_s(FDR))
    end;

 procedure print_FDRs(FDRs: PFDRs; top: pint; title: string);
     var   i: int;
     begin
         i:= 0; while (i<1) and print_str(PortNo,_CR+_LF) do inc (i);
         if i<1 then Exit;
         if not print_head(PortNo, _PRN_TAB+title+_CR+_LF) then Exit;
         if not print_str(PortNo,_CR+_LF) then Exit;

         i:= 0; while (i<=int(top^)) and print_FDR(FDRs^[i]) do
           begin
             CheckProcesses;
             inc(i)
           end;
         if i>=int(top^) then print_str(PortNo, kbNL)
     end;
{$ENDIF}
