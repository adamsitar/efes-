{ ---------------------
  DB
  ---------------------
}
 procedure _codeDB0_PRS(PRS: PPRS; buff: PDB_buff; desc: PDB_head); far;
     var   s : string;
     begin
       s:= code0_PRS_(PRS);
       {$IFDEF NET} s:= s+KON_SPR+rectostr(PRS^.rec); {$ENDIF}
       str_toDBstr(s,buff^[0]);
     end;

 procedure _decodeDB0_PRS(buff: PDB_buff; PRS: PPRS; desc: PDB_head); far;
     var   s: string;
     begin
       Move(buff^[0],s[0],ord(buff^[0][0])+1);
       decode0_PRS_(s, PRS);
       {$IFDEF NET}
        strtorec(getstr(s,2,[KON_SPR]), PRS^.rec);
       {$ENDIF}
       format_PRS (PRS)
     end;


 procedure _codeDBB_PRS(PRS: PPRS; buff: PDB_buff; desc: PDB_head); far;
     var   size: int;
           s,t: string;
     begin
       with PRS^ do
         begin
          { data
          }
           s:= '';
           add_s(@kod[0],sizeof(kod), s,t);

           add_s(@vys1[0],sizeof(vys1), s,t);
           add_s(@vys2[0],sizeof(vys2), s,t);
           add_s(@vys1p[0],sizeof(vys1p), s,t);
           add_s(@vys2p[0],sizeof(vys2p), s,t);

           add_s(@zac, sizeof(zac), s,t);
           add_s(@kon, sizeof(kon), s,t);
           add_s(@zacp,sizeof(zacp),s,t);
           add_s(@konp,sizeof(konp),s,t);

           add_s(@unt[0], sizeof(unt), s,t);
           add_s(@stat[0],sizeof(stat),s,t);
           add_s(@let[0], sizeof(let),s,t);

           add_s(@dap,sizeof(dap),s,t);
           add_s(@das,sizeof(das),s,t);

           add_s(@typ, sizeof(typ),s,t);

          { doplnene udaje o sprave aup
          }
           add_s(@zac_aup, sizeof(zac_aup), s,t);
           add_s(@kon_aup, sizeof(kon_aup), s,t);
           add_s(@vys1_aup[0],sizeof(vys1_aup), s,t);
           add_s(@vys2_aup[0],sizeof(vys2_aup), s,t);

           str_toDBstr_(s,buff^[db_PRS_data]);


          { poznamka
          }
           str_toDBstr(strpas(PRS^.pozn),buff^[db_PRS_18]);

          { prevzatie spravy
            - ine udaje, pri kazdej zmene upravit i
               "_codeDBB_PRSrec"
          }
           s:= '';
           add_s(@rec,sizeof(rec), s,t);
           str_toDBstr_(s,buff^[db_PRS_ine])
         end;
     end;

 procedure _decodeDBB_PRS(buff: PDB_buff; PRS: PPRS; desc: PDB_head); far;
     var   s,t : string;
           i : int;
           p : pchars;
     begin
       fillchar(PRS^,sizeof(PRS^),0);
       with PRS^ do
         begin
          { data
          }
           s:= DBstr_to_str_(buff^[db_PRS_data]); p:= @s[1];
           get_s(p, @kod[0],sizeof(kod));

           get_s(p, @vys1[0],sizeof(vys1));
           get_s(p, @vys2[0],sizeof(vys2));
           get_s(p, @vys1p[0],sizeof(vys1p));
           get_s(p, @vys2p[0],sizeof(vys2p));

           get_s(p, @zac, sizeof(zac));
           get_s(p, @kon, sizeof(kon));
           get_s(p, @zacp,sizeof(zacp));
           get_s(p, @konp,sizeof(konp));

           get_s(p, @unt[0], sizeof(unt));
           get_s(p, @stat[0],sizeof(stat));
           get_s(p, @let[0], sizeof(let));

           get_s(p, @dap,sizeof(dap));
           get_s(p, @das,sizeof(das));

           get_s(p, @typ,sizeof(typ));

          { doplnene udaje o sprave aup
          }
           get_s(p, @zac_aup, sizeof(zac_aup));
           get_s(p, @kon_aup, sizeof(kon_aup));
           get_s(p, @vys1_aup[0],sizeof(vys1_aup));
           get_s(p, @vys2_aup[0],sizeof(vys2_aup));


          { poznamka
          }
           PRS^.pozn:= strpasnew(DBstr_to_str (buff^[db_PRS_18]));

          { prevzatie spravy
          }
           s:= DBstr_to_str_(buff^[db_PRS_ine]); p:= @s[1];
           get_s(p, @rec,sizeof(rec));
         end;
     end;


 procedure _codeDBT_PRS(PRS: PPRS; buff: PDB_buff; desc: PDB_head); far;
     var   s : string;
     begin
       str_toDBstr(code_PRS_data(PRS),buff^[db_PRS_data]);
       str_toDBstr(strpas(PRS^.pozn),buff^[db_PRS_18]);
       str_toDBstr(code_PRS_19(PRS,true),buff^[db_PRS_19]);
       s:= '' {$IFDEF NET} + icao_ARR + rectostr(PRS^.rec) {$ENDIF};
       str_toDBstr(s,buff^[db_PRS_ine])
     end;

 procedure _decodeDBT_PRS(buff: PDB_buff; PRS: PPRS; desc: PDB_head); far;
     var   res, s,t : string;
           i : int;
     begin
       fillchar(PRS^,sizeof(PRS^),0);

       decode_PRS_data (DBstr_to_str (buff^[db_PRS_data]), PRS, res,false);
       PRS^.pozn:= strpasnew(DBstr_to_str (buff^[db_PRS_18]));
       decode_PRS_19 (DBstr_to_str (buff^[db_PRS_19]), PRS);

       s:= DBstr_to_str (buff^[db_PRS_ine]); i:= 1;
       {$IFDEF NET} strtorec(getstr(s,i,[icao_ARR]), PRS^.rec);
       {$ENDIF}

       {format_PRS(PRS);}
     end;
