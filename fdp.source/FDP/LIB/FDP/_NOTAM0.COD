function code0_NTM_data(NTM: PNTM): string;
   var   s : string;
   begin
     with NTM^ do
       begin
         s:=              format_s(strpas(_NTM))

             + icao_ARR + format_s(strpas(_Q))

             + icao_ARR + format_s(_A)

             + icao_ARR             + format_s(_B)
                        + icao_NXIT + format_s(_C)

             + icao_ARR             + format_s(_F)
                        + icao_NXT  + format_s(_G)


             + icao_ARR            + format_s (let)
                        + icao_NXT + code_l4_datums(dap)
                        {+ icao_NXT + code_l4_date (dav)
                        + icao_NXT + stt}
       end;
     code0_NTM_data:= s
   end;

procedure decode0_NTM_data(s: string; NTM: PNTM);
   var    t : string;
   begin
     fillchar(NTM^,sizeof(TNTM),0);
     with NTM^ do
       begin
         _NTM := strpasnew(GetStr(s,1,[icao_STD,icao_ARR]));
         _Q   := strpasnew(GetStr(s,2,[icao_STD,icao_ARR]));

         _A   := GetStr(s,3,[icao_ARR]);

         t:= GetStr(s,4,[icao_ARR]);
         _B:= GetStr(t,1,[icao_NXIT]);
         _C:= GetStr(t,2,[icao_NXIT]);
         {decode_l4_datum (GetStr(t,1,[icao_NXIT]),_B);
         decode_l4_datum (GetStr(t,2,[icao_NXIT]),_C);}

         t := GetStr(s,5,[icao_ARR]);
         _F:= GetStr(t,1,[icao_NXT]);
         _G:= GetStr(t,2,[icao_NXT]);

         t := GetStr(s,6,[icao_ARR]);
         let := GetStr(t,1,[icao_NXT]);
         decode_l4_datums (GetStr(t,2,[icao_NXT]),dap);
         {decode_l4_date (GetStr(t,3,[icao_NXT]),dav);
         stt := GetStr(t,4,[icao_NXT])}
       end
   end;


procedure code0_NTM(NTM: PNTM; var pkt: TNETpkt);
    var   s : array[1..db_NTM_RIADKOV] of string;
          p : word;
    begin
      s[1]:= icao_STD + code0_NTM_data (NTM);                          p:=   length(s[1]);
      s[2]:= icao_ARR + code_line_i_   (NTM^._D,1,3,kbNL);             inc(p,length(s[2]));
      s[3]:= icao_ARR + code_line_i_   (NTM^._E,1,4,kbNL);             inc(p,length(s[3]));
      s[4]:=            code_line_i_   (NTM^._E,5,8,kbNL);             inc(p,length(s[4]));
      s[5]:=            code_line_i_   (NTM^._E,9,10,kbNL) + icao_END; inc(p,length(s[5]));

      if not new_NETpkt_data (nil,p, pkt.pkt) then Exit;
      move(s[1][1],pkt.pkt.data^[0],length(s[1])); p:=   length(s[1]);
      move(s[2][1],pkt.pkt.data^[p],length(s[2])); inc(p,length(s[2]));
      move(s[3][1],pkt.pkt.data^[p],length(s[3])); inc(p,length(s[3]));
      move(s[4][1],pkt.pkt.data^[p],length(s[4])); inc(p,length(s[4]));
      move(s[5][1],pkt.pkt.data^[p],length(s[5])); inc(p,length(s[5]));
    end;

procedure decode0_NTM(const pkt: TNETpkt; NTM: PNTM);
    var   s : string;
          p : pchar;
          k : int;
          res  : string;
          data : pchars;
          size : word;
    begin
      data:= pkt.pkt.data;
      size:= pkt.pkt.dlz;

      fillchar(NTM^,sizeof(NTM^),0);
      frame_l4_pkt(data,size, res);

      p:= get_strs0(data,size, 1,5, [icao_ARR]);
      decode0_NTM_data(strpas(p), NTM);
      strdispose(p);

      NTM^._D:= get_strs0(data,size, 6,6, [icao_ARR]);

      k:= get_str_items(data,size,[icao_ARR]);
      p:= get_strs0(data,size, 7,Maximum(7,k), [icao_ARR]);
      NTM^._E:= strnew(decode_l4_p(p,true));
      strdispose(p);

      {$IFDEF NET}
        rec_data(pkt.ods, NTM^.rec);
      {$ENDIF}

      format_NTM_(NTM{,'','',0}) {!}
    end;

