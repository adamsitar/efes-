 procedure code_PRS_mess(PRS: PPRS; var pkt: TNETpkt);
     var   s: string;
     begin
       s:=    icao_STD + hd_PRS{decode_code_to_hd(pkt.head.typ)}
            + icao_ARR + codekey_PRS(PRS)
            + icao_ARR + PRS^.stat
            + icao_END;
       new_NETpkt_data (@s[1],length(s), pkt.pkt)
     end;

 procedure decode_PRS_mess(const pkt: TNETpkt; PRS: PPRS);
     var   s: string;
           i: int;
     begin
       s:= get_str(pkt.pkt.data,pkt.pkt.dlz,1,[icao_STD,icao_END],sizeof(s)-1);
       i:= pos(icao_ARR,s);  { odfiltrovanie hlavicky }
       if i>0 then s:= copy(s,i+1,length(s)-i);
       decodekey_PRS(s,PRS)
     end;


{$IFDEF DATA_BIN}
  { I _PRS0.cod}
  {$I _PRSS.cod}
  {$I _PRS0RDP.cod}
{$ENDIF}


{ ---------------------
  kodovanie pre DB
  ---------------------
}
 {$I _PRS_DB.cod}

 procedure codeDB_PRS (PRS: PPRS; buff: PDB_buff; desc: PDB_head);
     begin
       if desc^.attr and DBbin <> 0 then _codeDBB_PRS(PRS,buff,desc)
       {$IFDEF OPL} else if desc^.attr and DBtxt = 0 then _codeDB0_PRS(PRS,buff,desc) {$ENDIF}
       else _codeDBT_PRS(PRS,buff,desc)
     end;

 procedure decodeDB_PRS(buff: PDB_buff; PRS: PPRS; desc: PDB_head);
     begin
       fillchar(PRS^,sizeof(PRS^),0);
       if desc^.attr and DBbin <> 0 then _decodeDBB_PRS(buff,PRS,desc)
       {$IFDEF OPL} else if desc^.attr and DBtxt = 0 then _decodeDB0_PRS(buff,PRS,desc) {$ENDIF}
       else _decodeDBT_PRS (buff,PRS,desc);
     end;


 { ---------------------
   kluc
   ---------------------
 }

 function codekey_PRS(PRS: PPRS): string;
    begin
      if PRS<>nil then with PRS^ do
        codekey_PRS:=
                      mtks_rus_to_lat
                      (
                                     format_s (kod)
                       + icao_ARR  + format_s (let)
                       + icao_ARR  + code_l4_date (das)
                       {IFDEF PRS_PLAN}
                        + icao_NXT + code_l4_datums (dap)
                       {ENDIF}
                      )
      else codekey_PRS:= ''
    end;

 procedure decodekey_PRS(key: string; PRS: PPRS);
     var   t : string;
     begin
       fillchar(PRS^,sizeof(PRS^),0);         { nesmie sa zrusit ! }
       if PRS<>nil then with PRS^ do
         begin
           kod:= getstr(key,1,[icao_ARR]);
           let:= getstr(key,2,[icao_ARR]);
           t:= getstr(key,3,[icao_ARR]);
           decode_l4_date   (getstr(t,1,[icao_NXT]),das);
           {IFDEF PRS_PLAN}
            decode_l4_datums (getstr(t,2,[icao_NXT]),dap)
           {ENDIF}
           ;
         end
     end;


 function codekey_PRS_RPL(PRS: PPRS): string; far;
    begin
      with PRS^ do
        codekey_PRS_RPL:=
                         mtks_rus_to_lat
                         (
                            format_s(kod)
                          + icao_ARR + format_s(let)
                          {+ icao_ARR + code_l4_datums (dap)}
                         )
    end;
