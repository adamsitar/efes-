 { ---------------------
   kodovanie pre DB
   ---------------------
 }

 {$I _QGO_DB.cod}

 procedure codeDB_QGO (QGO: PQGO; buff: PDB_buff; desc: PDB_head);
     begin
       if desc^.attr and DBbin <> 0 then _codeDBB_QGO(QGO,buff,desc)
       {$IFDEF OPL} else if desc^.attr and DBtxt = 0 then _codeDB0_QGO(QGO,buff,desc) {$ENDIF}
       else _codeDBT_QGO(QGO,buff,desc)
     end;

 procedure decodeDB_QGO(buff: PDB_buff; QGO: PQGO; desc: PDB_head);
     begin
       fillchar(QGO^,sizeof(QGO^),0);
       if desc^.attr and DBbin <> 0 then _decodeDBB_QGO(buff,QGO,desc)
       {$IFDEF OPL} else if desc^.attr and DBtxt = 0 then _decodeDB0_QGO(buff,QGO,desc) {$ENDIF}
       else _decodeDBT_QGO (buff,QGO,desc);
     end;


 { ---------------------
   kluc
   ---------------------
 }

 function codekey_QGO(QGO: PQGO): string;
    begin
      codekey_QGO:=   mtks_rus_to_lat(upstring(
                                   format_s(_mairbase(QGO^.kod))
                      + icao_ARR + code_l4_date(QGO^.date)
                     {+ icao_ARR + code_l4_datums(QGO^.dap)}
                      ))
    end;

 procedure decodekey_QGO(key: string; QGO: PQGO);
     begin
       fillchar(QGO^,sizeof(QGO^),0);
       QGO^.kod:= getstr(key,1,[icao_ARR]);
       decode_l4_date(getstr(key,2,[icao_ARR]),QGO^.date);
       {decode_l4_datum(getstr(s,3,[icao_ARR]),QGO^.dap);}
     end;


 function codekey_QGO_RPL(QGO: PQGO): string; far;
    begin
      codekey_QGO_RPL:=   codekey_QGO(QGO) + icao_ARR
                        + code_l4_datums(QGO^.dap)
    end;

 procedure decodekey_QGO_RPL(s: string; QGO: PQGO); far;
     begin
       decodekey_QGO(s,QGO);
       decode_l4_datum(getstr(s,3,[icao_ARR]),QGO^.dap)
     end;