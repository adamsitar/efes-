{$IFDEF PRN}
 function print_PLN(PLN: PPLN): bool;
    begin
      print_PLN:= print_str(PortNo,code_PLN_s(PLN))
    end;


 procedure print_PLNs(PLN: PPLNs; top: pint; title: string); far;
     var   i: int;
     begin
       i:= 0; while (i<1) and print_str(PortNo,_CR+_LF) do inc (i);
       if i<1 then Exit;
       if not print_head(PortNo, _PRN_TAB+title+_CR+_LF) then Exit;
       {if not print_str (PortNo,_PRN_TAB+_CS+tu+_CE+_CR+_LF) then Exit;
       if not print_str (PortNo,_PRN_TAB+_CS+ti+_CE+_CR+_LF) then Exit;
       if not print_str (PortNo,_PRN_TAB+_CS+tu+_CE+_CR+_LF) then Exit;}
       if not print_str(PortNo,_CR+_LF) then Exit;

       i:= 0; while (i<=int(top^)) and print_PLN(PLN^[i]) do
         begin
           CheckProcesses;
           inc(i)
         end;
       if i>=int(top^) then print_str(PortNo,kbNL)
     end;

{$ENDIF}
