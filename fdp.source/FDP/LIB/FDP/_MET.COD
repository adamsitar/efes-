{ ---------------------
   DB
  --------------------- }

procedure codeDB_MET(MET: PMET; buff: PDB_buff; desc: PDB_head);
    var   s : string;
    begin
      s:= code_MET_(MET);
      {$IFDEF NET}
        s:= s + rectostr(MET^.rec) + KON_SPR;
      {$ENDIF}
      Move(s[0],buff^[0],length(s)+1);
    end;

procedure decodeDB_MET(buff: PDB_buff; MET: PMET; desc: PDB_head);
    var   s : string;
    begin
      Move(buff^[0],s[0],ord(buff^[0][0])+1);
      decode_MET_(s, MET);
     {$IFDEF NET}
       strtorec(getstr(s,2,[KON_SPR]), MET^.rec)
     {$ENDIF}
    end;


{ ---------------------
   prenos
  --------------------- }

procedure code_MET(MET: PMET; pkt: PNETpacket);
    var   s : string;
    begin
      s:= code_MET_(MET);
      Move(s[1],pkt^.data[0],length(s));
      pkt^.head.dlz:= length(s)
    end;

procedure decode_MET(pkt: PNETpacket; MET: PMET);
    var    s : string;
    begin
      init_str(@pkt^.data[0],pkt^.head.dlz, s);
      decode_MET_(s, MET)
      {$IFDEF NET};
        pkt_sender(pkt, MET^.rec);
      {$ENDIF}
    end;


