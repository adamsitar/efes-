{$I ..\lib\mnu\_system.h}

procedure mnuUTC_init(MMenu: PSubmenu); far;
    var   smnu  : TPItems;
          sbmnu : PSubMenu;
          i,items,nl, j,p : int;
    begin
      items:= 0; nl:= 0;

      smnu[items]:= Switch2 (I_UTC,@UTC_SYNCHRONIZE,nil);
      inc(items);
      smnu[items]:= Switch2 (M_UTC,@CASOVE_ZNAMENIE,nil);
      inc(items);
      smnu[items]:= NewLine2(0,nil);
      inc(items);
      smnu[items]:= Item    (C_UTC, cmTIMEset,nil);
      inc(items);

      for i:= 0 to items-1 do AddItemToMenu(MMenu,smnu[i])
    end;


procedure mnuTLAC_init(MMenu: PSubmenu); far;
    var   smnu  : TPItems;
          sbmnu : PSubMenu;
          i,items,nl, j,p : int;
    begin
      items:= 0; nl:= 0;

      smnu[items]:= Switch2_(TL_NET, @PRN_NET, @is_PRN_NET, true,nil);
      inc(items);
      smnu[items]:= SwitchI (TL_OFF, @PRN_TAB,'',PRN_TAB_lo,PRN_TAB_hi,nil);
      inc(items);
      smnu[items]:= NewLine2(0,nil);
      inc(items);
      smnu[items]:= Item (TL_TEST, cmPRN_TEST,nil);
      inc(items);

      for i:= 0 to items-1 do AddItemToMenu(MMenu,smnu[i])
    end;


