  ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
}

function O_L4444._code_EST (var FPL: DFPL4): pchar;
   var   p: pchar;
   begin
     with FPL do p:= StrPasNew
       (
                    _7
        +icao_ARR + _13
        +icao_ARR + _14
        +icao_ARR + _16
        +icao_ARR
       );
     p:= StrNCopy(p,FPL._15,true,false);
     p:= StrNCopy(p,FPL._18,true,false);
     _code_EST:= p
   end;


function O_L4444.send_EST (var FPL: DFPL4; key: string; typ: TNETtyp): bool;
   var   p: pchar;
   begin
      p:= _code_EST(FPL);
      send_EST:= p<>nil;
      if p<>nil then
         begin
           send_data(NODE_REMOTE, hd_ICAO[msEST],'','', pchars(p),strlen(p), key,typ);
           StrDispose(p)
         end
   end;
