 procedure O_L4444._decode_EST (data: pchars; size: word; var FPL: DFPL4; var res: string);
    begin
      res:= '';
      FPL._3 := get_str   (data,size, 1,odd_ICAO, sizeof(FPL._3)-1);
      FPL._7 := get_str   (data,size, 2,odd_ICAO, sizeof(FPL._7)-1);
      FPL._8 := get_str   (data,size, 3,odd_ICAO, sizeof(FPL._8)-1);
      FPL._9 := get_str   (data,size, 4,odd_ICAO, sizeof(FPL._9)-1);
      FPL._13:= get_str   (data,size, 5,odd_ICAO, sizeof(FPL._13)-1);
      FPL._14:= get_str   (data,size, 6,odd_ICAO, sizeof(FPL._14)-1);
      FPL._16:= get_str   (data,size, 7,odd_ICAO, sizeof(FPL._16)-1);
      FPL._15:= get_str0  (data,size, 8,odd_ICAO);
      FPL._18:= get_strs0 (data,size, 9,Maximum(9,get_str_items(data,size,odd_ICAO)), odd_ICAO);
    end;

 function O_L4444._process_EST (data: pchars; size: word; var FPL: DFPL4; var res: string): bool;
    begin
      _process_EST:= false
    end;

 function O_L4444.decode_EST (data: pchars; size: word; var FPL: DFPL4; var res: string): bool;
    begin
      _decode_EST(data,size, FPL, res);
      decode_EST:= (res='') and _process_EST(data,size, FPL, res)
    end;
