{ ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
   FPL
  ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
}
function O_L4444._code_FPL (var FPL: DFPL4): pchar;
   var   pch: pchar;
   begin
     with FPL do pch:= StrPasNew
       (
                    _7
        +icao_ARR + _8
        +icao_ARR + _9
        +icao_ARR + _10
        +icao_ARR + _13
        +icao_ARR
       );
     pch:= StrNCopy(pch,FPL._15,true,false);
     pch:= StrNPCopy(pch,icao_ARR+FPL._16+icao_ARR, true,true);
     if FPL._18<>nil then pch:= StrNCopy(pch,FPL._18, true,false)
     else pch:= StrNPCopy(pch,'0', true,true);
     _code_FPL:= pch
   end;


function O_L4444.send_FPL(var FPL: DFPL4; key: string; typ: TNETtyp): bool;
   var   pch: pchar;
   begin
      pch:= _code_FPL(FPL);
      send_FPL:= pch<>nil;
      if pch<>nil then
         begin
           send_data(NODE_REMOTE, hd_ICAO[msFPL],'','', pchars(pch),strlen(pch), key,typ);
           StrDispose(pch)
         end
   end;


{ ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
   CHG
  ˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙˙
}
function O_L4444._code_CHG (var FPL: DFPL4): pchar;
   var   pch: pchar;
   begin
     with FPL do pch:= StrPasNew
       (
                    getstr(_7,1,[icao_NXT])
        +icao_ARR + copy(_13,1,kod_AP)
        +icao_ARR + copy(_16,1,kod_AP)
        +icao_ARR
       );
     pch:= StrNCopy(pch,FPL._22,true,false);
     _code_CHG:= pch
   end;

function O_L4444.send_CHG(var FPL: DFPL4; key: string; typ: TNETtyp): bool;
   var   pch: pchar;
   begin
      pch:= _code_CHG(FPL);
      send_CHG:= pch<>nil;
      if pch<>nil then
         begin
           send_data(NODE_REMOTE, hd_ICAO[msCHG],'','', pchars(pch),strlen(pch), key,typ);
           StrDispose(pch)
         end
   end;


