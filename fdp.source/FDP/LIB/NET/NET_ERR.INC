function NETmsg(err: word): PChar;
   begin
    {$IFDEF SLOVAK}
      case err of
         netBAD_ADDR        : NETmsg:= 'Neznáma adresa.';
         netSELF_ADDR       : NETmsg:= 'Sám sebe?.';
         netTIME_OUT        : NETmsg:= 'Správa nebola potvrdená.';
         netNOT_INITIALIZED : NETmsg:= 'Neinicializovaná sieč.';
         netNOT_TrasaOK     : NETmsg:= 'Stanica neodpovedá.';

         netBRIDGE_MIS      : NETmsg:= 'Nedefinovaný alebo nepristupný bridge.';
         netNOT_SENDED      : NETmsg:= 'Správa nebola odoslaná.';
         netNOT_BUFFER      : NETmsg:= 'Nedostatok pamäte pre spracovanie paketu.';

         ipxNOT_INITIALIZED : NETmsg:= 'Neinicializovaná sieč.';            { neinicializovana }
         ipxNOT_CONNECTED   : NETmsg:= 'Stanica nie je pripojená v LAN.';   { nepripojeny uzol }
         ipxBAD_ADDR        : NETmsg:= 'Neznáma adresa v LAN.';
         ipxNOT_TrasaOK     : NETmsg:= 'Stanica v LAN neodpovedá.';
         ipxNOT_BridgeOK    : NETmsg:= 'Komunikaçnś poçítaç neodpovedá.';

         x25NOT_INITIALIZED : NETmsg:= 'Neinicializovaná sieč X25.';             { neinicializovana }
         x25NOT_CONNECTED   : NETmsg:= 'Stanica nie je pripojená do X25.';
         x25BAD_ADDR        : NETmsg:= 'Neznáma adresa v X25.';
         x25NOT_CALL        : NETmsg:= 'Spojenie X25 bolo odmietnuté.';

         x25BRIDGE_NOT_CONNECTED : NETmsg:= 'Komunikaçnś poçítaç odpojenś.';

         rtrBAD_ADDR        : NETmsg:= 'Neznáma adresa pre protokol routera.';
         netADDR_DUPL       : NETmsg:= 'Duplicitná adresa.'

         else NETmsg:= 'Chyba v komunikácii.';
      end;
    {$ENDIF}

    {$IFDEF CZECH}
      case err of
         netBAD_ADDR        : NETmsg:= 'Neznáma adresa.';
         netSELF_ADDR       : NETmsg:= 'Sám sobł.';
         netTIME_OUT        : NETmsg:= 'Zpráva nebyla potvrzena.';
         netNOT_INITIALIZED : NETmsg:= 'Neinicializovaná síč.';
         netNOT_TrasaOK     : NETmsg:= 'Stanice neodpovídá.';

         netBRIDGE_MIS      : NETmsg:= 'Nedefinovaný nebo nepęístupný bridge.';
         netNOT_SENDED      : NETmsg:= 'Zpráva nebyla odeslaná.';
         netNOT_BUFFER      : NETmsg:= 'Nedostatek pamłti pro zpracování paketu.';

         ipxNOT_INITIALIZED : NETmsg:= 'Neinicializovaná síč.';          { neinicializovana }
         ipxNOT_CONNECTED   : NETmsg:= 'Stanice není pęipojená v LAN.';  { nepripojeny uzol }
         ipxBAD_ADDR        : NETmsg:= 'Neznáma adresa v LAN.';
         ipxNOT_TrasaOK     : NETmsg:= 'Stanice v LAN neodpovídá.';
         ipxNOT_BridgeOK    : NETmsg:= 'Komunikaçní poçítaç neodpovídá.';

         x25NOT_INITIALIZED : NETmsg:= 'Neinicializovaná síč X25.';             { neinicializovana }
         x25NOT_CONNECTED   : NETmsg:= 'Stanice není pęipojena do X25.';
         x25BAD_ADDR        : NETmsg:= 'Neznáma adresa v X25.';
         x25NOT_CALL        : NETmsg:= 'Spojení X25 bylo odmítnuto.';

         x25BRIDGE_NOT_CONNECTED : NETmsg:= 'Komunikaçní poçítaç odpojen.';

         rtrBAD_ADDR        : NETmsg:= 'Neznáma pro protokol routru.';
         netADDR_DUPL       : NETmsg:= 'Duplicitná adresa.'

         else NETmsg:= 'Chyba v komunikaci.';
      end;
    {$ENDIF}

    {$IFDEF ENGLISH}
      case err of
         netBAD_ADDR        : NETmsg:= 'Unknown address.';
         netSELF_ADDR       : NETmsg:= 'Own address.';
         netTIME_OUT        : NETmsg:= 'Message not accepted.';
         netNOT_INITIALIZED : NETmsg:= 'Network not initialized.';
         netNOT_TrasaOK     : NETmsg:= 'Workstation doesn`t respond.';

         netBRIDGE_MIS      : NETmsg:= 'Undefined or unreacheable bridge.';
         netNOT_SENDED      : NETmsg:= 'Data not sended.';
         netNOT_BUFFER      : NETmsg:= 'Not enough memory to process the packet.';

         ipxNOT_INITIALIZED : NETmsg:= 'LAN not initialized.';

         ipxNOT_CONNECTED   : NETmsg:= 'Workstation is not connected to LAN.';
         ipxBAD_ADDR        : NETmsg:= 'Unknown LAN address.';
         ipxNOT_TrasaOK     : NETmsg:= 'LAN workstation doesn`t respond.';
         ipxNOT_BridgeOK    : NETmsg:= 'Communication computer doesn`t respond.';

         x25NOT_INITIALIZED : NETmsg:= 'X25 network is not initialized.';             { neinicializovana }
         x25NOT_CONNECTED   : NETmsg:= 'Workstation is not connected to X25.';
         x25BAD_ADDR        : NETmsg:= 'Unknown X25 address.';
         x25NOT_CALL        : NETmsg:= 'X25 call was not accpeted.';

         x25BRIDGE_NOT_CONNECTED : NETmsg:= 'Communication computer disconnected.';

         rtrBAD_ADDR        : NETmsg:= 'Unknown address for router protocol.';
         netADDR_DUPL       : NETmsg:= 'Error in the adress assigning.'


         else NETmsg:= 'NET error.';
      end;
    {$ENDIF}

    {$IFDEF PCTCP}
     if (err >= net_TCP_IP) and (err <= net_TCP_IP+max_neterr_list) then NETmsg:= neterr_list[err-net_TCP_IP]
    {$ENDIF}
   end; { NETmsg }
