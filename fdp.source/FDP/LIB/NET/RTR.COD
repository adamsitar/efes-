function code_NETpkt_to_RTRpkt (const Np : TNETpkt; var Rp : TRTRpkt_bin;
                                distribute : PBplan_rec;
                                protocol   : TRTRprotocol;
                                var whole  : bool
                               ): word; far;

   var   astrx        : byte;
         pocet,p,i,nd : int;
         adr, RTBadr  : TRTRadr;
         Lp           : bool;
         kod, dlz_pkt,dlz_data,dlz_head,dlz_adr : word;

   begin
     code_NETpkt_to_RTRpkt:= 0;
     whole:= false;

     fillchar(Rp,SizeOf(Rp),0);
     astrx := kod_ASTERIX_0A;
     Rp[0] := kod_RTR_PKT;
     dlz_pkt := 0;

    { Naplnenie pola adries
    }
     if (protocol=rpRTR) and (distribute<>nil) then
        begin
          pocet:= 0;
          Lp:= false;
          nd:= -1;

          for i:= 0 to NODEpoc-1 do
            if (NODEs^[i].desc.pro=RTR) and (distribute^[i]) then
               begin
                 inc(pocet);
                 adr:= NODEs^[i].desc.adrr; {NETadr_rtr(NODEs^[i].desc.adr);}
                 Move(adr,Rp^[2+(pocet-1)*sizeof(TRTRadr)],sizeof(adr))
               end
        end

     else begin
            pocet:= 1;
            Lp:= is_proL(Np^.head.adr);
            nd:= is_NETadr(Np^.head.adr);

            case isRTR of

              rpRTR :
                 begin
                   adr:= NETadr_rtr(Np^.head.adr);
                   if (adr=0) then pocet:= 0
                 end;

              rpRTB :
                 begin
                   adr:= RBRIDGEadr;
                   if nd>-1 then RTBadr:= NODEs^[nd].desc.adrr
                   else RTBadr:= 0;
                 end

              else adr:= RTRadr  { rpRTI,rpLRTI }
            end;

            if pocet<>1 then Exit;
            Move(adr,Rp^[2],sizeof(adr))
          end;

    { Naplnenie ostatnych poloziek : p + dlz_head + dlz_data + dlz_adr <= size_of_RTRdata_0...
    }
     if pocet>0 then
        begin
          dlz_head := 1 + sizeof(Np^.head.typ) + sizeof(Np^.head.cis); { dlzka hlavicky v datach }
          if Lp then inc(dlz_head, sizeof(Np^.head.ind) + sizeof(Np^.head.poc));
          dlz_adr  := 0;                                               { dlzka dodatocnej adresy }
          dlz_data := Np^.pkt.dlz;                                     { dlzka dat               }

          Rp^[1]:= pocet;

          p:= N(pocet-1)*sizeof(TRTRadr);  { preskocenie zaplneneho pola adries }

          Rp^[3+p]:= kod_ASTERIX_0A;

          Rp^[4+p]:= lo(RTR_cis);  { 4 }
          Rp^[5+p]:= hi(RTR_cis);  { 5 }
          {$IFOPT R+} {$DEFINE R} {$R-} {$ENDIF} inc(RTR_cis); {$IFDEF R} {$UNDEF R} {$R+} {$ENDIF}

          if protocol=rpRTB then
             begin
               if RTBadr<>0 then
                  begin
                    kod:= rspr_RTB1;
                    dlz_adr:= sizeof(TRTRadr)
                  end
               else begin
                      kod:= rspr_RTB2;
                      dlz_adr:= sizeof(TNETadr)
                    end
             end
           else begin
               if (isRTR=rpRTR) and (not pkt_from_this_node(Np)) then
                  begin
                    kod:= rspr_RT_;
                    dlz_adr:= sizeof(TNETadr)
                  end
               else kod:= rspr_RTR
             end;


          if astrx=kod_ASTERIX_0A then
             begin
               dlz_data:= Minimum(Minimum(dlz_data, size_of_RTRdata{_0A}-(p+dlz_head+dlz_adr)),size_of_NETdata);
               dlz_pkt := dlz_head+dlz_data+dlz_adr;
               Rp^[6+p]:= lo(dlz_pkt); { 6 }
               Rp^[7+p]:= hi(dlz_pkt); { 7 }
               inc(p,8)
             end
          else begin
                 dlz_data:= Minimum(Minimum(dlz_data, size_of_RTRdata_02-(p+dlz_head+dlz_adr)),size_of_NETdata);
                 dlz_pkt := dlz_head+dlz_data+dlz_adr;
                 Rp^[6+p]:= dlz_pkt;
                 inc(p,7)
               end};

         { pole dat obsahuje  word kod + word cis + data
         }
          if Lp then inc(kod,rspr_LONGoffs);
          Rp^[p]  := kod;

          Rp^[p+1]:= lo(Np^.head.typ);         { 9  }
          Rp^[p+2]:= hi(Np^.head.typ);         { 10 }
          Rp^[p+3]:= lo(Np^.head.cis);         { 11 }
          Rp^[p+4]:= hi(Np^.head.cis);         { 12 }

          Move(Np^.pkt.data,Rp^[p+5],dlz_data); { 13 }

        { hlavicka ma 7(+1) byte + adresy }
          inc(dlz_pkt,p); { inc(dlz,7+p); if astrx=cnst_ASTERIX_0A then inc(dlz) }

          inc(p,dlz_head+dlz_data);
          { v dlz_pkt je uz na zaciatku dlz_adr }

        { pri smerovani ku RBRIDGE pripajam ciselnu alebo textovu adresu }
          if (kod in [rspr_RTB1,rspr_RTB2]) {isRTR=rpRTB} then
             begin
               if RTBadr<>0 then Move(RTBadr,Rp^[p],sizeof(RTBadr))
               else if nd>-1 then Move(NODEs^[nd].desc.adr[0],Rp^[p],length(NODEs^[nd].desc.adr)+1)
                    else Move(Np^.head.adr[0],Rp^[p],length(Np^.head.adr)+1);
             end

        { pri odosielani z RBRIDGE pripajam adresu odosielatela }
          else if (kod=rspr_RT_) then
                  begin
                    Move(Np^.head.ods[0],Rp^[p],length(Np^.head.ods)+1)
                  end

        { uz nemozem nic doplnit, lebo length(adr)+1<sizeof(TNETadr) }
        end;

     len_ok:= dlz_data = Np^.head.dlz;
     code_NETpkt_to_RTRpkt:= dlz_pkt
   end;



{ ------------------------------------------
   RTRpaket -> NETpaket
  ------------------------------------------

{
  Zisti typ paketu v router sieti a transformuje ho na TROUTERpacket_0A.
  Spracovavane asterix typy su cnst_ASTERIX_02 a cnst_ASTERIX_0A;
}
function decode_RTRpkt_bin_to_RTRpkt(Rp: PRTRpkt_bin; Rp0A: PRTRpacket{_0A}): bool;
   var   pom : byte;
         p   : pointer;
   begin
     decode_RTRpkt_bin_to_RTRpkt:= false;

     p:= Rp;
     move(p^,Rp0A^.head.prizn,sizeof(Rp0A^.head.prizn)); incptr(p,sizeof(Rp0A^.head.prizn));
     if Rp0A^.head.prizn<>kod_RTR_PKT then Exit;

     move(p^,Rp0A^.head.pocet,sizeof(Rp0A^.head.pocet)); incptr(p,sizeof(Rp0A^.head.pocet));
     move(p^,Rp0A^.head.adr,  sizeof(Rp0A^.head.adr));   incptr(p,sizeof(Rp0A^.head.adr));
     move(p^,Rp0A^.head.astrx,sizeof(Rp0A^.head.astrx)); incptr(p,sizeof(Rp0A^.head.astrx));
     move(p^,Rp0A^.head.cis,  sizeof(Rp0A^.head.cis));   incptr(p,sizeof(Rp0A^.head.cis));

     case Rp0A^.head.astrx of
        kod_ASTERIX_02 : begin
                           move(p^,pom,1);
                           Rp0A^.head.dlz:= Minimum(pom,size_of_RTRdata_02);
                           incptr(p,sizeof(pom))
                         end;
        kod_ASTERIX_0A : begin
                           move(p^,Rp0A^.head.dlz,sizeof(Rp0A^.head.dlz));
                           Rp0A^.head.dlz:= Minimum(Rp0A^.head.dlz,size_of_RTRdata{_0A});
                           incptr(p,sizeof(Rp0A^.head.dlz))
                         end
        else Exit
     end;

     move(p^,Rp0A^.head.kod,sizeof(Rp0A^.head.kod));

     if (Rp0A^.head.kod in[rspr_SYS,rspr_RTR,rspr_RT_, rspr_RTB1,rspr_RTB2]) then
        begin
          move(p^,Rp0A^.data,Rp0A^.head.dlz);
          decode_RTRpkt_bin_to_RTRpkt:= true
        end
   end;


{
  Zisti kod spravy a transformuje ho na NETpacket podla mnoziny povolenych
  kodov : [rspr_SYS, rspr_RDP, rspr_FDP, rspr_OLD_lo..rspr_OLD_hi].
}
function code_RTRpkt_to_NETpkt(Rp: PRTRpkt_bin; Np: PNETpacket): bool;
   var   Rp0A : PRTRpacket{_0A};
         res  : bool;
         Radr : TRTRadr;
         Nadr : TNETadr;
         dlz_data,dlz_head,dlz_adr : word;
   label X;
   begin { IFDEF DEBUG  lan_done; ENDIF}
     New(Rp0A); FillChar(Rp0A^,sizeof(Rp0A^),0);
     res:= decode_RTRpkt_bin_to_RTRpkt(Rp, Rp0A);
     if not res then goto X;

     dlz_head:= 1 + sizeof(Np^.head.typ) + sizeof(Np^.head.cis);
     Move(Rp0A^.data[1],Np^.head.typ,2);
     Move(Rp0A^.data[3],Np^.head.cis,2);

     dlz_data:= Rp0A^.head.dlz-dlz_head;
     Np^.head.ods:= is_RTRadr(Rp0A^.head.adr);

     if Rp0A^.head.kod in [rspr_SYS,rspr_RTR,rspr_RT_] then
          begin
            Np^.head.adr:= RTRaddress;
            if Rp0A^.head.kod=rspr_RT_ then
               begin
                 dec(dlz_data,sizeof(TNETadr));
                 Move(Rp0A^.data[dlz_head+dlz_data],Nadr[0],sizeof(TNETadr));
                 Np^.head.ods:= Nadr
               end
          end

     else if Rp0A^.head.kod=rspr_RTB1 then
          begin
            dec(dlz_data,sizeof(TRTRadr));
            Move(Rp0A^.data[dlz_head+dlz_data],Radr,sizeof(TRTRadr));
            Np^.head.adr:= is_RTRadr(Radr)
          end

     else begin {rspr_RTB2}
            dec(dlz_data,sizeof(TNETadr));
            Move(Rp0A^.data[dlz_head+dlz_data],Nadr[0],sizeof(TNETadr));
            Nadr:= is_RTRadr(is_in_RTRadr(Nadr));
            Np^.head.adr:= Nadr
          end;

xxx     Np^.head.dlz:= Minimum(N(dlz_data),sizeof(Np^.data));
     Move(Rp0A^.data[dlz_head],Np^.data[0],Np^.head.dlz);

     X:
     code_RTRpkt_to_NETpkt:= res;
     Dispose(Rp0A)
   end;

