# Build harness output
fdp.source/COMPILE.LOG

# Output captured by utils/dos.sh (E:\AGENT.LOG inside DOSBox)
fdp.source/AGENT.LOG

# Demo runtime data (mutated whenever any FDP program starts up — IO.PAS:165
# appends a "System initialized" line, etc.). Tracked by mistake in the
# initial snapshot; restored once and untracked.
fdp.demo/idd/ERR.LOG
fdp.demo/idd/CRT.WIN

# BP IDE / DOSBox state files (e.g., W000.WIN at fdp.source root).
# Show up in unpredictable locations after a build run.
fdp.source/W*.WIN

# BPC build artifacts (regenerable; case-insensitive to catch .TPU/.tpu/.Tpu etc.)
# Note: gitignore only affects untracked files, so .TPU files already in the
# initial snapshot stay tracked and their modifications still register.
fdp.source/**/*.[Tt][Pp][Uu]
fdp.source/**/*.[Ee][Xx][Ee]
fdp.source/**/*.[Mm][Aa][Pp]
fdp.source/**/*.[Oo][Vv][Rr]

# Debug-workflow artifacts (created by debug-x.sh / TDBG.BAT / TD itself)
fdp.demo/idd/*.orig
fdp.demo/idd/TDCONFIG.TD

# EDD runtime archive dir (NBSP-prefixed "CMN"), recreated on each run
fdp.demo/idd/ CMN/
fdp.demo/idd/ NET/

# BP IDE desktop state (BP.TP is the saved options - keep it tracked)
fdp.demo/idd/BP.DSK
